# Hermetic runner for the unified `spec-tool` toolkit. Stdlib-only Python — no pip.
#
# The package is copied in at build for a default CMD; at run time a spec corpus
# is bind-mounted read-only at /work and the CLI is invoked from there (see the
# Makefile `check-podman`), so the image never goes stale as specs change and
# REPO_ROOT / sibling imports resolve against the live tree under /work.
FROM docker.io/library/python:3.12-slim

WORKDIR /work
COPY spec-tool/ /opt/spec-tool/
ENV PYTHONDONTWRITEBYTECODE=1

ENTRYPOINT ["python3"]
CMD ["/opt/spec-tool/cli.py", "--help"]
